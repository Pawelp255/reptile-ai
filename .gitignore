# --- Bundles / review exports ---
# When creating a zip for code review, exclude: .git/, node_modules/, dist/, build/, .env*, and OS junk.
# (Those paths are already ignored below where applicable.)

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

node_modules
dist
dist-ssr
*.local
.env
.env.*
!.env.example

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.cursor/
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Bun (optional; ignore if using npm)
bun.lock
bun.lockb
bunfig.toml
.bun/

# Vite / build / output folders
build
out

# Coverage / caches
coverage
.cache/
.vite/

# TypeScript incremental
*.tsbuildinfo

# OS / local junk
Thumbs.db
Desktop.ini
